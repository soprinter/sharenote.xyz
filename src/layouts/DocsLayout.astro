---
import HeadSEO from "@/components/core/HeadSEO.astro";
import Header from "@/components/core/Header.astro";
import Footer from "@/components/core/Footer.astro";
import { Copy } from "@/components/core/Copy";

import SideNavMenu from "@/components/docs/SideNavMenu.astro";
import TableofContent from "@/components/docs/TableofContents.astro";
import MainContent from "@/components/docs/MainContent.astro";

import type { DocsLayoutProps } from "@/lib/types";
import { capitalizeFirstLetter } from "@/lib/utils";
import { menu } from "@/lib/content";

import { LOCALE, SITE, docconfig } from "@/config";

const {
  title,
  author,
  pubDatetime,
  modDatetime,
  description,
  draft,
  tags,
  hide_breadcrumbs,
  hide_toc,
  hide_sidenav,
  max_width,
  headings,
} = Astro.props as DocsLayoutProps;
---

<!doctype html>
<html lang=`${LOCALE.lang ?? "en"}` class="scroll-smooth">
  <head>
    <HeadSEO
      title=`${title ? capitalizeFirstLetter(title) + " | " + SITE.title : SITE.title}`
      description={description}
    />
  </head>
  <body
    class=`font-sans ${hide_toc && hide_sidenav && max_width ? "" : "bg-background"}`
  >
    <Copy client:only="react" />
    <div class="flex flex-col min-h-screen">
      <Header class="guilloche-bg fixed top-0 inset-x-0 z-40" />
      <!-- Spacer to offset fixed header height -->
      <div aria-hidden="true" class="h-[var(--header-h,69px)]"></div>
      <main class="flex flex-1 flex-col md:flex-row container">
        <div
          class=`py-4 hidden md:flex max-h-static_sidemenu sticky
          ${hide_toc && hide_sidenav && max_width ? "w-screen" : "md:px-6 md:w-1/4 lg:w-1/5"}`
          style="top: var(--header-h, 69px)"
        >
          <div class="h-full w-full overflow-y-auto">
            {
              !docconfig.hide_side_navigations && !hide_sidenav && (
                <SideNavMenu items={menu} level={0} />
              )
            }
          </div>
        </div>
        <div
          class=`bg-card w-full ${hide_toc && hide_sidenav && max_width ? "" : "md:w-3/4 lg:w-3/5"}`
        >
          <MainContent
            title={title}
            author={author}
            pubDatetime={pubDatetime}
            modDatetime={modDatetime}
            description={description}
            draft={draft}
            tags={tags}
            hide_breadcrumbs={hide_breadcrumbs}
            headings={headings}
          >
            <slot />
          </MainContent>
        </div>
        <div
          class=`py-4 hidden lg:flex max-h-static_sidemenu sticky ${hide_toc && hide_sidenav && max_width ? "" : "px-6 lg:w-1/5"}`
          style="top: var(--header-h, 69px)"
        >
          <div class="h-full w-full overflow-y-auto">
            {
              !docconfig.hide_table_of_contents && !hide_toc && (
                <TableofContent {headings} />
              )
            }
          </div>
        </div>
      </main>
      <Footer class="bg-background" />
    </div>
    <script is:inline>
      (function adjustDocsHeaderHeight() {
        function getHeaderEl() {
          const el = document.querySelector('header');
          return el instanceof HTMLElement ? el : null;
        }
        function update() {
          const header = getHeaderEl();
          const h = header ? Math.round(header.getBoundingClientRect().height) : 69;
          document.documentElement.style.setProperty('--header-h', h + 'px');
        }
        requestAnimationFrame(update);
        window.addEventListener('resize', update, { passive: true });
        document.addEventListener('astro:page-load', update);
      })();
    </script>
  </body>
</html>
