---
import SideNavMenu from "@/components/docs/SideNavMenu.astro";

import { Button } from "@/components/ui/button";

import { MenuIcon, X } from "lucide-react";

import { menu } from "@/lib/content";

import { docconfig } from "@/config";
---

<style is:global>
  .menu-overlay {
    opacity: 0;
    pointer-events: none;
    visibility: hidden;
    transform: translateY(-8px);
    transition: opacity 0.3s cubic-bezier(0.16, 1, 0.3, 1),
                transform 0.3s cubic-bezier(0.16, 1, 0.3, 1),
                visibility 0s 0.3s;
  }

  .menu-overlay.active {
    opacity: 1;
    pointer-events: auto;
    visibility: visible;
    transform: translateY(0);
    transition: opacity 0.3s cubic-bezier(0.16, 1, 0.3, 1),
                transform 0.3s cubic-bezier(0.16, 1, 0.3, 1),
                visibility 0s 0s;
  }
</style>

<div onclick="toggleMenu()">
  <Button variant={"ghost"} size="icon" client:load>
    <MenuIcon className="h-[1.2rem] w-[1.2rem]" />
  </Button>
</div>

<div
  class="menu-overlay z-[100] fixed top-0 w-full h-[100dvh] left-0 px-6 py-4 bg-background/95 backdrop-blur-xl flex flex-col"
>
  <div onclick="closeMenu()" class="flex justify-end">
    <Button variant={"ghost"} size="icon" client:load>
      <X className="h-[1.2rem] w-[1.2rem]" />
    </Button>
  </div>
  <div class="flex-1 min-h-0 overflow-y-auto mb-4 px-6">
    {
      !docconfig.hide_side_navigations && (
        <SideNavMenu items={menu} level={0} class="w-full" />
      )
    }
  </div>
</div>

<script is:inline>
  function toggleMenu() {
    const menuOverlay = document.querySelector(".menu-overlay");
    if (menuOverlay) {
      menuOverlay.classList.toggle("active");
    }
  }

  function closeMenu() {
    const menuOverlay = document.querySelector(".menu-overlay");
    if (menuOverlay) {
      menuOverlay.classList.remove("active");
    }
  }
</script>
