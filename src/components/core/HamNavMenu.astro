---
import SideNavMenu from "@/components/docs/SideNavMenu.astro";

import { Button } from "@/components/ui/button";
import { Separator } from "@/components/ui/separator";
import { ScrollArea } from "@/components/ui/scroll-area";

import { MenuIcon, X } from "lucide-react";

import { menu } from "@/lib/content";

import { menu_items, docconfig } from "@/config";

const pathname: string = new URL(Astro.request.url).pathname;
const pathname_part: string = pathname.split("/")[1];
---

<style>
  .menu-overlay {
    opacity: 0;
    pointer-events: none;
    transform: translateY(-8px);
    transition: opacity 0.3s cubic-bezier(0.16, 1, 0.3, 1), transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .menu-overlay.active {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }

  .stagger-item {
    opacity: 0;
    transform: translateY(10px);
    transition: opacity 0.4s cubic-bezier(0.16, 1, 0.3, 1), transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .menu-overlay.active .stagger-item {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<div onclick="toggleMenu()">
  <Button variant={"ghost"} size="icon" client:load>
    <MenuIcon className="h-[1.2rem] w-[1.2rem]" />
  </Button>
</div>

<div
  class="menu-overlay z-[100] fixed top-0 w-full h-[100dvh] left-0 px-6 py-4 bg-background/95 backdrop-blur-xl flex flex-col"
>
  <div onclick="closeMenu()" class="flex justify-end">
    <Button variant={"ghost"} size="icon" client:load>
      <X className="h-[1.2rem] w-[1.2rem]" />
    </Button>
  </div>
  <ScrollArea className=" w-full h-dynamic_hscreen mb-4" client:only="react">
    <div class="flex flex-col items-start px-6">
      {
        !docconfig.hide_side_navigations && (
          <div class="w-full stagger-item" style="transition-delay: 60ms">
            <SideNavMenu items={menu} level={0} class="px-4" />
          </div>
        )
      }
    </div>
  </ScrollArea>
</div>

<script is:inline>
  function toggleMenu() {
    const menuOverlay = document.querySelector(".menu-overlay");
    if (menuOverlay) {
      menuOverlay.classList.toggle("active");
    }
  }

  function closeMenu() {
    const menuOverlay = document.querySelector(".menu-overlay");
    if (menuOverlay) {
      menuOverlay.classList.remove("active");
    }
  }
</script>
