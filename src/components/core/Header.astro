---
import HamNavMenu from "@/components/core/HamNavMenu.astro";
import NavMenu from "@/components/core/NavMenu.astro";

import { Button } from "@/components/ui/button";

import { docconfig, SITE } from "@/config";
import { menu as docsMenu } from "@/lib/content";
import { buildSearchIndex } from "@/lib/search-index";

const searchIndex = await buildSearchIndex();

// To pass the tailwindcss classes to the astro component
const { class: className } = Astro.props;
---

<header
  class:list={["py-4 px-4 md:px-16 lg:px-48 w-full", className]}
>
  <div
    class="flex space-x-4 justify-between items-center md:items-center md:space-x-0 md:max-w-8xl"
  >
    <div class="font-bold flex flex-row items-center">
      <a href="/" class="px-4 hidden md:flex no-underline header-logo-link" data-astro-reload>
        <Button
          client:load
          className="flex items-center gap-3 hover:no-underline hover:bg-transparent hover:text-inherit text-2xl"
          variant="ghost"
        >
          <span class="logo-wrap relative inline-flex items-center justify-center">
            <img src="/guilloche-rosette.svg" alt="" aria-hidden="true" class="rosette-overlay" />
            <img src="/logo.png" src="/logo.png" srcset="/optimized/logo-w320.png 320w, /optimized/logo-w480.png 480w, /optimized/logo-w640.png 640w" alt="Sharenote home" class="h-8 w-auto block relative z-[1]" />
          </span>
        </Button>
      </a>
      <a href="/" class="px-2 flex md:hidden header-logo-link" data-astro-reload>
        <Button
          client:load
          className="flex items-center gap-2 hover:no-underline hover:bg-transparent hover:text-inherit text-xl"
          variant="ghost"
        >
          <span class="logo-wrap relative inline-flex items-center justify-center">
            <img src="/guilloche-rosette.svg" alt="" aria-hidden="true" class="rosette-overlay" />
            <img src="/logo.png" alt="Sharenote home" class="h-8 w-auto block relative z-[1]" />
          </span>
        </Button>
      </a>
      <div class="hidden md:block">
        <NavMenu />
      </div>
    </div>

    <div class="flex flex-row gap-3 min-[390px]:gap-4 md:gap-2 md:px-8 items-center">
      <button id="cmdk-button" class="btn-icon" aria-label="Search (Cmd/Ctrl+K)">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
      </button> 
     <!-- <Search client:only="react" /> -->

      {!docconfig.hide_repo_button && (
        <a
          href={SITE.repo}
          target="_blank"
          class="btn-icon hover:no-underline"
          aria-label="GitHub"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
            <path d="M12 .5A11.5 11.5 0 0 0 .5 12.3c0 5.25 3.41 9.7 8.15 11.28.6.12.82-.27.82-.59 0-.29-.01-1.07-.02-2.1-3.32.73-4.02-1.64-4.02-1.64-.55-1.43-1.34-1.81-1.34-1.81-1.09-.77.08-.75.08-.75 1.2.09 1.83 1.26 1.83 1.26 1.07 1.86 2.8 1.32 3.49 1.01.11-.79.42-1.32 .76-1.63-2.65-.31-5.44-1.36-5.44-6.05 0-1.34.47-2.44 1.25-3.3-.13-.31-.54-1.56.12-3.26 0 0 1.01-.33 3.3 1.26.96-.27 1.99-.4 3.02-.4s2.06.14 3.02.4c2.29-1.59 3.3-1.26 3.3-1.26.67 1.7.25 2.95.12 3.26.78.86 1.25 1.96 1.25 3.3 0 4.71-2.8 5.74-5.46 6.04.44.38.82 1.12.82 2.25 0 1.62-.01 2.93-.01 3.33 0 .32.21.72.83.59 4.74-1.58 8.14-6.03 8.14-11.28A11.5 11.5 0 0 0 12 .5Z"/>
          </svg>
        </a>
      )}

      <button id="theme-toggle" class="btn-icon" aria-label="Toggle color theme" aria-pressed="false">
        <svg id="sun" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="4"/><path d="M12 2v2m0 16v2m10-10h-2M4 12H2m15.364-7.364-1.414 1.414M7.05 16.95l-1.414 1.414m0-11.314L7.05 7.05m10.9 10.9 1.414 1.414"/></svg>
        <svg id="moon" class="hidden" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 12.79A9 9 0 1 1 11.21 3a7 7 0 0 0 9.79 9.79Z"/></svg>
      </button>

      <div class="md:hidden flex flex-row-reverse items-center gap-4">
        <HamNavMenu />
      </div>
    </div>
  </div>
</header>

<!-- Search overlay -->
<div id="search-overlay" class="search-overlay" aria-modal="true" role="dialog">
  <div class="search-panel">
    <div class="search-input-row">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
      <input id="search-input" class="search-input" type="text" placeholder="Search docs..." aria-label="Search docs" autocomplete="off" spellcheck="false" />
      <div class="search-controls">
        <kbd class="search-kbd hidden md:inline-block">Esc</kbd>
        <button id="search-close" class="search-close-btn" aria-label="Close search">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 6 6 18M6 6l12 12"/></svg>
        </button>
      </div>
    </div>
    <div id="search-results" class="search-results"></div>
    <div id="search-footer" class="search-footer">
      <span><kbd>&uarr;</kbd><kbd>&darr;</kbd> navigate</span>
      <span><kbd>&crarr;</kbd> open</span>
    </div>
  </div>
</div>

<script is:inline>
  function setDarkMode(document) {
    const getThemePreference = () => {
      try {
        const v = localStorage.getItem('theme');
        if (v === 'dark' || v === 'light') return v;
      } catch {}
      // Default to light; do not follow system preference
      return 'light';
    };
    const isDark = getThemePreference() === 'dark';
    document.documentElement.classList[isDark ? "add" : "remove"]("dark");

    if (typeof localStorage !== "undefined") {
      const observer = new MutationObserver(() => {
        const isDark = document.documentElement.classList.contains("dark");
        localStorage.setItem("theme", isDark ? "dark" : "light");
      });
      observer.observe(document.documentElement, {
        attributes: true,
        attributeFilter: ["class"],
      });
    }
  }

  setDarkMode(document);

  document.addEventListener("astro:before-swap", (ev) => {
    setDarkMode(ev.newDocument);
  });

  // Theme toggle and search: init on load and after navigation
  (function () {
    function initTheme() {
      const btn = document.getElementById('theme-toggle');
      const sun = document.getElementById('sun');
      const moon = document.getElementById('moon');
      function refreshIcon(doc) {
        const isDark = doc.documentElement.classList.contains('dark');
        if (sun && moon) {
          sun.classList.toggle('hidden', isDark);
          moon.classList.toggle('hidden', !isDark);
        }
        if (btn) btn.setAttribute('aria-pressed', String(isDark));
      }
      function toggle(doc) {
        const isDark = doc.documentElement.classList.toggle('dark');
        try { localStorage.setItem('theme', isDark ? 'dark' : 'light'); } catch {}
        refreshIcon(doc);
      }
      if (btn && !btn.hasAttribute('data-bound')) {
        btn.addEventListener('click', () => toggle(document));
        btn.setAttribute('data-bound', 'true');
      }
      refreshIcon(document);
    }
    initTheme();
    document.addEventListener('astro:page-load', initTheme);
  })();
</script>

<script define:vars={{ searchIndex }}>
  (function () {
    // Fuse.js inline (lightweight fuzzy search)
    let fuseInstance = null;
    let fuseLoaded = false;
    let activeIdx = -1;

    function loadFuse() {
      if (fuseLoaded) return Promise.resolve();
      return import('https://cdn.jsdelivr.net/npm/fuse.js@7.0.0/dist/fuse.mjs').then(mod => {
        const Fuse = mod.default;
        fuseInstance = new Fuse(searchIndex, {
          includeScore: true,
          includeMatches: true,
          threshold: 0.35,
          minMatchCharLength: 2,
          keys: [
            { name: 'title', weight: 3 },
            { name: 'description', weight: 2 },
            { name: 'headers', weight: 2 },
            { name: 'body', weight: 0.5 },
          ],
        });
        fuseLoaded = true;
      });
    }

    function highlight(text, indices) {
      if (!indices || !indices.length) return esc(text);
      const pairs = indices.slice().sort((a, b) => a[0] - b[0]);
      let result = '';
      let last = 0;
      for (const [start, end] of pairs) {
        if (start > last) result += esc(text.slice(last, start));
        result += '<mark>' + esc(text.slice(start, end + 1)) + '</mark>';
        last = end + 1;
      }
      if (last < text.length) result += esc(text.slice(last));
      return result;
    }

    function esc(s) {
      const d = document.createElement('div');
      d.textContent = s;
      return d.innerHTML;
    }

    function initSearch() {
      const overlay = document.getElementById('search-overlay');
      const input = document.getElementById('search-input');
      const container = document.getElementById('search-results');
      const footer = document.getElementById('search-footer');
      const openBtn = document.getElementById('cmdk-button');
      const closeBtn = document.getElementById('search-close');
      if (!overlay || !input || !container) return;

      function open() {
        overlay.classList.add('is-open');
        document.body.style.overflow = 'hidden';
        input.value = '';
        activeIdx = -1;
        render('');
        requestAnimationFrame(() => input.focus());
        loadFuse();
      }

      function close() {
        overlay.classList.remove('is-open');
        document.body.style.overflow = '';
        input.value = '';
        container.innerHTML = '';
        activeIdx = -1;
      }
      
      if (closeBtn) {
        closeBtn.addEventListener('click', (e) => {
          e.stopPropagation();
          close();
        });
      }

      function getLinks() {
        return Array.from(container.querySelectorAll('a.search-result-link'));
      }

      function setActive(idx) {
        const links = getLinks();
        links.forEach((a, i) => a.classList.toggle('is-active', i === idx));
        activeIdx = idx;
        if (links[idx]) links[idx].scrollIntoView({ block: 'nearest' });
      }

      function render(q) {
        const query = (q || '').trim();
        container.innerHTML = '';
        activeIdx = -1;

        if (!query) {
          // Show all pages grouped by category
          const grouped = {};
          for (const entry of searchIndex) {
            const cat = entry.category || 'Other';
            if (!grouped[cat]) grouped[cat] = [];
            grouped[cat].push(entry);
          }
          for (const [cat, entries] of Object.entries(grouped)) {
            const group = document.createElement('div');
            group.className = 'search-group';
            group.innerHTML = '<div class="search-group-label">' + esc(cat) + '</div>';
            for (const entry of entries) {
              group.innerHTML += buildItem(esc(entry.title), '', entry.href);
            }
            container.appendChild(group);
          }
          if (footer) footer.style.display = '';
          return;
        }

        if (!fuseInstance) {
          // Fallback: simple includes match while Fuse loads
          const lq = query.toLowerCase();
          const matches = searchIndex.filter(e =>
            e.title.toLowerCase().includes(lq) ||
            (e.description && e.description.toLowerCase().includes(lq)) ||
            e.headers.toLowerCase().includes(lq)
          ).slice(0, 12);
          for (const entry of matches) {
            container.innerHTML += buildItem(esc(entry.title), entry.description ? esc(entry.description) : '', entry.href);
          }
          if (!matches.length) {
            container.innerHTML = '<div class="search-empty">No results for "' + esc(query) + '"</div>';
          }
          if (footer) footer.style.display = '';
          return;
        }

        const results = fuseInstance.search(query, { limit: 12 });
        if (!results.length) {
          container.innerHTML = '<div class="search-empty">No results for "' + esc(query) + '"</div>';
          if (footer) footer.style.display = '';
          return;
        }

        for (const { item, matches } of results) {
          const titleMatch = matches && matches.find(m => m.key === 'title');
          const descMatch = matches && matches.find(m => m.key === 'description');
          const titleHtml = titleMatch ? highlight(item.title, titleMatch.indices) : esc(item.title);
          const descHtml = descMatch && item.description ? highlight(item.description, descMatch.indices) : (item.description ? esc(item.description) : '');
          container.innerHTML += buildItem(titleHtml, descHtml, item.href);
        }
        if (footer) footer.style.display = '';
      }

      function buildItem(titleHtml, descHtml, href) {
        return '<a class="search-result-link" href="' + href + '">' +
          '<span class="search-result-title">' + titleHtml + '</span>' +
          (descHtml ? '<span class="search-result-desc">' + descHtml + '</span>' : '') +
          '</a>';
      }

      if (openBtn && !openBtn.hasAttribute('data-search-bound')) {
        openBtn.addEventListener('click', open);
        openBtn.setAttribute('data-search-bound', 'true');
      }

      function onKeydown(e) {
        if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === 'k') {
          e.preventDefault();
          if (overlay.classList.contains('is-open')) close(); else open();
          return;
        }
        if (!overlay.classList.contains('is-open')) return;
        if (e.key === 'Escape') { e.preventDefault(); close(); return; }
        const links = getLinks();
        if (e.key === 'ArrowDown') {
          e.preventDefault();
          setActive(activeIdx < links.length - 1 ? activeIdx + 1 : 0);
        } else if (e.key === 'ArrowUp') {
          e.preventDefault();
          setActive(activeIdx > 0 ? activeIdx - 1 : links.length - 1);
        } else if (e.key === 'Enter' && activeIdx >= 0 && links[activeIdx]) {
          e.preventDefault();
          close();
          window.location.href = links[activeIdx].getAttribute('href');
        }
      }

      // Use capture to avoid duplicate listeners
      if (!overlay.hasAttribute('data-keys-bound')) {
        document.addEventListener('keydown', onKeydown);
        overlay.setAttribute('data-keys-bound', 'true');
      }

      overlay.addEventListener('click', (e) => { if (e.target === overlay) close(); });

      let debounceTimer = 0;
      input.addEventListener('input', () => {
        clearTimeout(debounceTimer);
        debounceTimer = setTimeout(() => render(input.value), 80);
      });

      // Click on result closes overlay
      container.addEventListener('click', (e) => {
        if (e.target.closest('a.search-result-link')) close();
      });
    }

    initSearch();
    document.addEventListener('astro:page-load', initSearch);
  })();
</script>

<style>
  .logo-wrap { --logo-h: 2rem; display: inline-grid; place-items: center; }
  .logo-wrap img[alt="Logo"] { height: var(--logo-h); width: auto; }
  .logo-wrap .rosette-overlay {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    width: calc(var(--logo-h) * 4.5);
    height: calc(var(--logo-h) * 4.5);
    pointer-events: none;
    z-index: 0;
    opacity: 0.9;
  }
  .header-logo-link:hover { text-decoration: none; }
  .header-logo-link:hover, .header-logo-link:focus { color: inherit; background: transparent; }


</style>

<style is:global>
  /* ── Search overlay (global — elements created via JS innerHTML) ── */
  #search-overlay {
    position: fixed; inset: 0;
    display: flex; align-items: flex-start; justify-content: center;
    background: rgba(0,0,0,0.35); backdrop-filter: blur(6px); -webkit-backdrop-filter: blur(6px);
    padding: 12vh 16px 16px;
    z-index: 100;
    opacity: 0; pointer-events: none;
    transition: opacity 180ms ease;
  }
  #search-overlay.is-open { opacity: 1; pointer-events: auto; }

  .search-panel {
    width: 100%; max-width: 560px;
    background: var(--bg); color: var(--ink);
    border-radius: 12px;
    box-shadow: 0 16px 48px rgba(0,0,0,0.18), 0 2px 8px rgba(0,0,0,0.08);
    border: 1px solid color-mix(in oklab, var(--ink) 10%, transparent);
    overflow: hidden;
    display: flex; flex-direction: column;
    max-height: 70vh;
    transform: translateY(-8px); transition: transform 180ms ease;
  }
  #search-overlay.is-open .search-panel { transform: translateY(0); }

  .search-input-row {
    display: flex; align-items: center; gap: 10px;
    padding: 14px 16px;
    border-bottom: 1px solid color-mix(in oklab, var(--ink) 8%, transparent);
    flex-shrink: 0;
  }
  .search-input-row svg { flex-shrink: 0; opacity: 0.5; }
  .search-input {
    flex: 1; min-width: 0;
    background: transparent; border: none; outline: none;
    font-size: 15px; color: var(--ink);
    font-family: inherit;
  }
  .search-input::placeholder { color: var(--ink-muted); }
  .search-kbd {
    flex-shrink: 0;
    font-size: 11px; font-family: inherit;
    color: var(--ink-muted);
    padding: 2px 6px; border-radius: 4px;
    border: 1px solid color-mix(in oklab, var(--ink) 12%, transparent);
    background: color-mix(in oklab, var(--ink) 4%, transparent);
    line-height: 1.4;
  }
  .search-controls { display: flex; align-items: center; gap: 8px; flex-shrink: 0; }
  .search-close-btn {
    display: inline-flex; align-items: center; justify-content: center;
    width: 32px; height: 32px; border-radius: 6px;
    background: transparent; border: none; color: var(--ink-muted);
    cursor: pointer; transition: background 150ms ease, color 150ms ease;
    padding: 0;
  }
  .search-close-btn:hover { background: color-mix(in oklab, var(--ink) 10%, transparent); color: var(--ink); }

  #search-results {
    overflow-y: auto; flex: 1 1 auto;
    padding: 8px;
    list-style: none;
  }

  .search-group { margin-bottom: 4px; }
  .search-group-label {
    font-size: 11px; font-weight: 600; text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--ink-muted);
    padding: 8px 10px 4px;
  }

  a.search-result-link {
    display: flex !important; flex-direction: column; gap: 2px;
    padding: 8px 10px; border-radius: 8px;
    text-decoration: none !important; color: var(--ink) !important;
    transition: background 100ms ease;
    cursor: pointer;
  }
  a.search-result-link:hover, a.search-result-link.is-active {
    background: color-mix(in oklab, var(--ink) 6%, transparent);
    text-decoration: none !important;
  }
  .search-result-title {
    display: block;
    font-size: 14px; font-weight: 500; line-height: 1.4;
  }
  .search-result-desc {
    display: block;
    font-size: 12px; color: var(--ink-muted); line-height: 1.4;
    overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
  }
  a.search-result-link mark {
    background: color-mix(in oklab, #f0c040 50%, transparent);
    color: inherit; border-radius: 2px; padding: 0 1px;
  }

  .search-empty {
    padding: 24px 10px; text-align: center;
    color: var(--ink-muted); font-size: 14px;
  }

  #search-footer {
    display: flex; gap: 16px; align-items: center; justify-content: center;
    padding: 8px 16px;
    border-top: 1px solid color-mix(in oklab, var(--ink) 8%, transparent);
    font-size: 11px; color: var(--ink-muted);
    flex-shrink: 0;
  }
  #search-footer kbd {
    display: inline-block;
    font-size: 11px; font-family: inherit;
    padding: 1px 5px; border-radius: 3px;
    border: 1px solid color-mix(in oklab, var(--ink) 12%, transparent);
    background: color-mix(in oklab, var(--ink) 4%, transparent);
    line-height: 1.4; margin: 0 2px;
  }

  @media (max-width: 640px) {
    #search-overlay { padding: 8px; align-items: flex-start; }
    .search-panel { max-height: 90vh; border-radius: 10px; }
    #search-footer { display: none; }
  }
</style>
