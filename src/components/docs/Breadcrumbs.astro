---
import { ChevronRight, Home } from "lucide-react";
import { SITE } from "@/config";

const { url } = Astro;
const pathSegments = url.pathname.split("/").filter((segment) => segment !== "");

const breadcrumbs = pathSegments.map((segment, index) => {
  const href = `/${pathSegments.slice(0, index + 1).join("/")}`;
  const label = segment
    .split("-")
    .map((word) => word.charAt(0).toUpperCase() + word.slice(1))
    .join(" ");
  return { label, href };
});
---

{
  breadcrumbs.length > 0 && (
    <nav class="flex items-center space-x-2 text-[10px] font-medium uppercase tracking-widest text-muted-foreground/60 mb-6 px-1" aria-label="Breadcrumb">
      <a href="/" class="hover:text-foreground transition-colors flex items-center gap-1">
        <Home size={10} />
      </a>
      {breadcrumbs.map((breadcrumb, index) => (
        <div class="flex items-center space-x-2">
          <ChevronRight size={10} strokeWidth={3} />
          {index === breadcrumbs.length - 1 ? (
            <span class="text-foreground/80 font-bold">{breadcrumb.label}</span>
          ) : (
            <a href={breadcrumb.href} class="hover:text-foreground transition-colors">
              {breadcrumb.label}
            </a>
          )}
        </div>
      ))}
    </nav>
  )
}
